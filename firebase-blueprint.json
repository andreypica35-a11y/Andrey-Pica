{
  "entities": {
    "User": {
      "title": "User",
      "description": "Public user profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["worker", "employer", "admin"] },
        "isVerified": { "type": "boolean" },
        "verificationStatus": { "type": "string", "enum": ["unverified", "pending", "verified", "rejected"] },
        "bio": { "type": "string" },
        "skills": { "type": "array", "items": { "type": "string" } },
        "experience": { "type": "string" },
        "rating": { "type": "number" },
        "reviewCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "role"]
    },
    "UserPrivate": {
      "title": "UserPrivate",
      "description": "Private user information (PII, balance, settings)",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "address": { "type": "string" },
        "balance": { "type": "number" },
        "linkedAccounts": { "type": "array", "items": { "type": "object" } },
        "idType": { "type": "string" },
        "idNumber": { "type": "string" },
        "idImageURL": { "type": "string" },
        "notificationPreferences": {
          "type": "object",
          "properties": {
            "newApplications": { "type": "boolean" },
            "messages": { "type": "boolean" },
            "gigStatusUpdates": { "type": "boolean" },
            "marketing": { "type": "boolean" }
          }
        }
      },
      "required": ["email"]
    },
    "Gig": {
      "title": "Gig",
      "description": "Short-term task or job posting",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "employerId": { "type": "string" },
        "employerName": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "payment": { "type": "number" },
        "location": { "type": "string" },
        "duration": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "in-progress", "review", "completed", "cancelled"] },
        "workerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["employerId", "title", "payment", "status"]
    },
    "Application": {
      "title": "Application",
      "description": "Worker application for a gig",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "gigId": { "type": "string" },
        "workerId": { "type": "string" },
        "workerName": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["gigId", "workerId", "status"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Payment transaction record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "gigId": { "type": "string" },
        "employerId": { "type": "string" },
        "workerId": { "type": "string" },
        "amount": { "type": "number" },
        "serviceFee": { "type": "number" },
        "workerAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "completed", "failed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["gigId", "employerId", "workerId", "amount"]
    },
    "Message": {
      "title": "Message",
      "description": "Chat message between users",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["chatId", "senderId", "text"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System notification for admins or users",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["verification_request", "system", "payment"] },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "message": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "userId", "message", "read", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Public user profiles"
    },
    "/users_private/{userId}": {
      "schema": "UserPrivate",
      "description": "Private user data"
    },
    "/gigs/{gigId}": {
      "schema": "Gig",
      "description": "Gig postings"
    },
    "/gigs/{gigId}/applications/{applicationId}": {
      "schema": "Application",
      "description": "Applications for a specific gig"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Payment logs"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Chat messages"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "System notifications"
    }
  }
}
