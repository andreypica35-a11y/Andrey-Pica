rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (
          request.auth.token.email == "andreypica35@gmail.com" ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
        );
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // User profiles
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
    }

    // Gigs
    match /gigs/{gigId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.employerId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.employerId == request.auth.uid || 
        isAdmin() || 
        (resource.data.workerId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])) ||
        (resource.data.status == 'open' && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['workerId', 'status']))
      );
      allow delete: if isAdmin();

      match /applications/{applicationId} {
        allow read: if isAuthenticated() && (
          resource.data.workerId == request.auth.uid || 
          get(/databases/$(database)/documents/gigs/$(gigId)).data.employerId == request.auth.uid ||
          isAdmin()
        );
        allow create: if isAuthenticated() && request.resource.data.workerId == request.auth.uid;
        allow update: if isAuthenticated() && (
          resource.data.workerId == request.auth.uid || 
          get(/databases/$(database)/documents/gigs/$(gigId)).data.employerId == request.auth.uid ||
          isAdmin()
        );
      }
    }

    // Transactions
    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && (resource.data.employerId == request.auth.uid || resource.data.workerId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated();
      allow update: if isAdmin();
    }

    // Chats
    match /chats/{chatId} {
      function isChatParticipant() {
        return isAuthenticated() && (
          chatId == "global_demo_chat" ||
          (resource != null && request.auth.uid in resource.data.participants) ||
          (resource == null && request.auth.uid in request.resource.data.participants) ||
          isAdmin()
        );
      }

      allow read: if isChatParticipant();
      allow create: if isAuthenticated() && (request.auth.uid in request.resource.data.participants || isAdmin());
      allow update: if isChatParticipant() && (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastMessage', 'updatedAt']) ||
        isAdmin()
      );
      
      match /messages/{messageId} {
        allow read: if isAuthenticated() && (
          chatId == "global_demo_chat" ||
          isAdmin() ||
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
        );
        allow create: if isAuthenticated() && (
          chatId == "global_demo_chat" ||
          isAdmin() ||
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
        ) && (request.resource.data.senderId == request.auth.uid || isAdmin());
      }
    }
  }
}
